# ── App runtime ───────────────────────────────────────────────────────────────
# local | databricks. Controls which service implementations are wired.
DE_AGENT_ENV=local
LOG_LEVEL=INFO
LOG_JSON=false

# Require human approval of each layer's SQL before execution (true|false)
REQUIRE_APPROVAL=true

# ── Databricks ────────────────────────────────────────────────────────────────
# On Databricks Apps these are injected automatically for the service principal.
# For local dev, set a PAT or use a profile.
DATABRICKS_HOST=https://<workspace>.cloud.databricks.com
DATABRICKS_TOKEN=
DATABRICKS_WAREHOUSE_ID=
# Target catalog the agent builds into. Set ALLOW_CREATE_CATALOG=true only if the
# service principal has CREATE CATALOG on the metastore; otherwise pre-create it.
TARGET_CATALOG=de_agent_dev
ALLOW_CREATE_CATALOG=false

# ── LLM ───────────────────────────────────────────────────────────────────────
# groq | databricks | fake
LLM_PROVIDER=groq
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
# Stronger model for the Gold reasoning / planning nodes (optional override)
GROQ_MODEL_REASONING=llama-3.3-70b-versatile
# Databricks serving endpoint name (used when LLM_PROVIDER=databricks)
DATABRICKS_LLM_ENDPOINT=databricks-claude-sonnet

# ── Checkpointer ──────────────────────────────────────────────────────────────
# Postgres/Lakebase connection string. Leave blank locally to use in-memory saver.
DATABASE_URL=
